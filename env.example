# UniFi controller — required for the UniFi backend.
UNIFI_HOST=192.168.1.1
UNIFI_USERNAME=shepard
UNIFI_PASSWORD=your-unifi-password-here
UNIFI_SITE=default
# UDM / UDM Pro / Cloud Gateway / Dream Router → 443
# Older standalone Network Application controllers → 8443
UNIFI_PORT=443

# Optional: Home Assistant long-lived access token. Only needed if you want
# kick/quarantine alerts pushed via HA's notify service. Leave blank to disable.
HA_TOKEN=your-ha-long-lived-token-here
