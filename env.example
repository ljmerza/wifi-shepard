# Secrets only. Everything non-secret (UniFi host/username/site/port, HA URL,
# Pi-hole URLs, all thresholds) now lives in config.yaml and is editable from the
# Settings UI (ADR-0013). In config.yaml a secret is referenced by the NAME of its
# env var, e.g. `password: ${UNIFI_PASSWORD}` — the value stays here and is resolved
# only inside the daemon, never in the UI or the browser.

# UniFi controller password — required for the UniFi backend.
UNIFI_PASSWORD=your-unifi-password-here

# Optional: Home Assistant long-lived access token. Only needed if you enable the
# home_assistant: notify block. Leave unset to disable.
HA_TOKEN=your-ha-long-lived-token-here

# Optional: Pi-hole v6 admin/API password. Only needed if you enable the
# dns_sources: Pi-hole block (ADR-0011 DNS-thrash detection). Shared across all
# instances listed under that source. Leave unset to disable.
PIHOLE_PASSWORD=your-pihole-password-here

# Optional: store state in MySQL/MariaDB instead of the default SQLite file at
# /data/state.db. One URL — mysql://user:password@host:3306/database — read by
# BOTH the daemon and the UI sidecar (set it in both env files), so the two
# always look at the same database. The daemon creates its tables in the named
# database on startup; the user needs full privileges on that database only.
# Unset = SQLite. Percent-encode any @ : / in the password; also remember docker
# compose interpolates env_file values, so a literal '$' must be written '$$'.
# WIFI_SHEPARD_DB_URL=mysql://wifi_shepard:your-db-password@your-db-host:3306/wifi_shepard
