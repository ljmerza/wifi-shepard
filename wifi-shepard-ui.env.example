# Bearer token required on every request except /healthz.
# Empty string is refused at startup -- either set a real token or leave the
# variable unset (auth disabled). See src/wifi_shepard_ui/app.py:77-82.
WIFI_SHEPARD_UI_TOKEN=replace-with-a-long-random-string

# Comma-separated MACs that are surfaced as "allowlisted" in the UI.
# Should mirror the daemon's allowlist: in config.yaml.
WIFI_SHEPARD_UI_ALLOWLIST=aa:bb:cc:dd:ee:ff,11:22:33:44:55:66
